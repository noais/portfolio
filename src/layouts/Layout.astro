---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'David Ferreira — Engineering Leader & Senior Mobile Engineer',
  description = 'Engineering leader and senior mobile engineer based in Portugal. 15+ years of software experience across iOS, Swift, real-time systems, and AI-augmented engineering.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://noais.github.io');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="David Ferreira" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="David Ferreira" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,400;0,600;1,300;1,400&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>
  <body>
    <slot />
    <script>
      const sections = document.querySelectorAll('section[id]');
      const navLinks = document.querySelectorAll('[data-nav]');
      const navObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              navLinks.forEach((link) => link.removeAttribute('data-active'));
              const active = document.querySelector(`[data-nav="${entry.target.id}"]`);
              if (active) active.setAttribute('data-active', 'true');
            }
          });
        },
        { threshold: 0.35 }
      );
      sections.forEach((s) => navObserver.observe(s));
    </script>
  </body>
</html>
