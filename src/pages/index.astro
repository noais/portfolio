---
import Layout from '../layouts/Layout.astro';

const experience = [
  {
    period: '2025 — Present',
    role: 'Head of Mobile / Lead Engineer',
    company: 'FRiNGE',
    outcomes: [
      'Built location-based livestreaming iOS product end-to-end — Swift 6/SwiftUI, Agora RTC, Supabase, PostHog',
      'Shipped from zero to TestFlight in 9 weeks; real-time camera/RTC handoff with zero reported crashes',
      'Led full mobile architecture decision-making across product, backend, and infra',
    ],
  },
  {
    period: '2023 — 2025',
    role: 'Senior iOS Developer',
    company: 'CARIAD (Volkswagen Group)',
    outcomes: [
      'Automotive platform architecture and release flows across European vehicle models',
      'Technical alignment across 4+ cross-functional squads; reduced release cycle from 3 weeks to 10 days',
      'Built internal tooling (Python, Bash, YAML) that automated 60% of manual release prep steps',
    ],
  },
  {
    period: '2021 — 2023',
    role: 'Senior iOS Developer',
    company: 'Mindera / Vodafone & MEO',
    outcomes: [
      'Led telecom iOS product serving 1M+ subscribers — zero Sev-1 incidents across 18-month engagement',
      'Introduced TCA architecture pattern adopted by 3 other squads in the org',
      'Mentored 4 mid-level engineers; 2 promoted to senior within the engagement',
    ],
  },
  {
    period: '2018 — 2021',
    role: 'iOS Developer',
    company: 'Various (agencies & products)',
    outcomes: [
      'Delivered 8+ iOS products across smart home, fintech, health, and outdoor sports verticals',
      'Introduced unit test coverage baseline that became studio-wide standard at two agencies',
    ],
  },
];

const capabilities = [
  {
    label: 'Mobile Product Engineering',
    items: ['iOS & Swift', 'Android & Kotlin', 'SwiftUI & UIKit', 'App Store / Play Store'],
  },
  {
    label: 'Real-time & Platform',
    items: ['WebSockets / MQTT', 'Swift Concurrency', 'Offline-first architecture', 'BLE & background modes'],
  },
  {
    label: 'AI-Augmented Delivery',
    items: ['LLM-assisted code review', 'Automated test generation', 'Claude API integration', 'AI pair-programming'],
  },
  {
    label: 'Leadership & Quality',
    items: ['Engineering management', 'Hiring & levelling', 'Architecture review', 'Cross-functional delivery'],
  },
];

const proofDomains = ['Automotive', 'Smart Home', 'Secure Messaging', 'Health', 'Telecom', 'Outdoor Sports'];
---

<Layout
  title="David Ferreira — Mobile products built to hold up."
  description="David Ferreira designs and leads durable iOS and Android products—from real-time experiences to the systems that keep teams shipping."
>

<!-- ─── NAV ─────────────────────────────────────────────────────── -->
<header class="nav-shell">
  <nav class="nav-inner">
    <a href="#top" class="nav-logo">DF</a>
    <ul class="nav-links">
      <li><a href="#work" data-nav="work">Work</a></li>
      <li><a href="#experience" data-nav="experience">Experience</a></li>
      <li><a href="#capabilities" data-nav="capabilities">Capabilities</a></li>
      <li><a href="#contact" data-nav="contact" class="nav-cta">Let's talk</a></li>
    </ul>
  </nav>
</header>

<!-- ─── HERO ──────────────────────────────────────────────────────── -->
<section id="top" class="hero-section">
  <div class="hero-grid">

    <!-- Left: copy -->
    <div class="hero-copy">
      <div class="hero-chips">
        <span class="chip">15+ yrs</span>
        <span class="chip">iOS · Android</span>
        <span class="chip">Portugal</span>
      </div>

      <h1 class="hero-headline">
        Mobile products<br />
        <em>built to hold up.</em>
      </h1>

      <p class="hero-sub">
        David Ferreira designs and leads durable iOS and Android products —
        from real-time experiences to the systems that keep teams shipping.
      </p>

      <div class="hero-actions">
        <a href="#work" class="btn-primary">See the work</a>
        <a href="#contact" class="btn-ghost">Let's talk</a>
      </div>
    </div>

    <!-- Right: phone composition -->
    <div class="hero-visual" aria-hidden="true">
      <div class="phone-stack">
        <div class="phone phone--back">
          <img src="/finpilot-overview.png" alt="" loading="eager" />
        </div>
        <div class="phone phone--front">
          <img src="/ridersnow-site/assets/01-live.png" alt="" loading="eager" />
        </div>
      </div>
      <div class="hero-topo"></div>
    </div>

  </div>
</section>

<!-- ─── PROOF STRIP ───────────────────────────────────────────────── -->
<div class="proof-strip">
  <p class="proof-label">Built across</p>
  <ul class="proof-domains">
    {proofDomains.map((d) => (
      <li>{d}</li>
    ))}
  </ul>
</div>

<!-- ─── WORK ──────────────────────────────────────────────────────── -->
<section id="work" class="section">
  <div class="section-inner">
    <div class="section-header">
      <span class="eyebrow">Selected work</span>
      <h2 class="section-title">Products that ship and stay shipped.</h2>
    </div>

    <!-- RidersNow — flagship -->
    <article class="case-card case-card--flagship">
      <div class="case-screens">
        <div class="case-phone case-phone--1">
          <img src="/ridersnow-site/assets/01-live.png" alt="RidersNow live map view" loading="lazy" />
        </div>
        <div class="case-phone case-phone--2">
          <img src="/ridersnow-site/assets/03-hosts.png" alt="RidersNow find riders view" loading="lazy" />
        </div>
        <div class="case-phone case-phone--3">
          <img src="/ridersnow-site/assets/04-create.png" alt="RidersNow create session view" loading="lazy" />
        </div>
      </div>

      <div class="case-body">
        <span class="case-tag">iOS · Android · Real-time · Outdoor Sports</span>
        <h3 class="case-title">RidersNow</h3>
        <p class="case-problem">
          <strong>Problem:</strong> Outdoor sports riders had no way to find or coordinate sessions in real time — events were stale by the time they were shared.
        </p>
        <p class="case-outcome">
          <strong>Outcome:</strong> Live map matching, BLE proximity detection, and push-coordinated sessions. Shipped cross-platform in 14 weeks, zero critical post-launch incidents.
        </p>
        <div class="case-stack">
          <span>Swift</span><span>Kotlin</span><span>WebSockets</span><span>BLE</span><span>MQTT</span>
        </div>
        <a href="https://davidferreira.dev/ridersnow-site/" target="_blank" rel="noopener" class="case-link">
          Visit RidersNow <span aria-hidden="true">↗</span>
        </a>
      </div>
    </article>

    <!-- FinPilot — secondary -->
    <article class="case-card case-card--secondary">
      <div class="case-body">
        <span class="case-tag">iOS · FinTech · AI</span>
        <h3 class="case-title">FinPilot</h3>
        <p class="case-problem">
          <strong>Problem:</strong> Retail investors were drowning in noise — no tool surfaced signal at the right moment on mobile.
        </p>
        <p class="case-outcome">
          <strong>Outcome:</strong> AI-curated alert engine with personalised portfolio narratives. 4.7 App Store rating, 60% D30 retention.
        </p>
        <div class="case-stack">
          <span>Swift</span><span>SwiftUI</span><span>Claude API</span><span>GraphQL</span>
        </div>
      </div>
    </article>

  </div>
</section>

<!-- ─── EXPERIENCE ─────────────────────────────────────────────────── -->
<section id="experience" class="section section--navy">
  <div class="section-inner">
    <div class="section-header section-header--light">
      <span class="eyebrow eyebrow--lime">Experience</span>
      <h2 class="section-title section-title--light">Outcomes, not job descriptions.</h2>
    </div>

    <ol class="timeline">
      {experience.map((role) => (
        <li class="timeline-item">
          <div class="timeline-meta">
            <span class="timeline-period">{role.period}</span>
          </div>
          <div class="timeline-body">
            <p class="timeline-role">{role.role}</p>
            <p class="timeline-company">{role.company}</p>
            <ul class="timeline-outcomes">
              {role.outcomes.map((o) => (
                <li>{o}</li>
              ))}
            </ul>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<!-- ─── CAPABILITIES ──────────────────────────────────────────────── -->
<section id="capabilities" class="section section--navy">
  <div class="section-inner">
    <div class="section-header section-header--light">
      <span class="eyebrow eyebrow--lime">Capabilities</span>
      <h2 class="section-title section-title--light">The full stack of mobile delivery.</h2>
    </div>

    <div class="caps-grid">
      {capabilities.map((cap) => (
        <div class="cap-panel">
          <h3 class="cap-title">{cap.label}</h3>
          <ul class="cap-items">
            {cap.items.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ─── CONTACT ───────────────────────────────────────────────────── -->
<section id="contact" class="section section--navy">
  <div class="section-inner contact-inner">
    <div class="contact-copy">
      <span class="eyebrow eyebrow--lime">Contact</span>
      <h2 class="contact-headline">
        Building a mobile product that needs to hold up under pressure?
      </h2>
      <p class="contact-sub">
        Available for senior engineering and engineering-lead roles. Based in Portugal, open to remote or hybrid across Europe.
      </p>
      <div class="contact-links">
        <a href="mailto:david.vicenteferreira@gmail.com" class="contact-link">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 7 10-7"/></svg>
          david.vicenteferreira@gmail.com
        </a>
        <a href="https://linkedin.com/in/david-ferreira-dev" target="_blank" rel="noopener" class="contact-link">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="3"/><path d="M7 10v7M7 7v.01M12 17v-4a2 2 0 0 1 4 0v4M12 10v7"/></svg>
          LinkedIn
        </a>
        <a href="https://github.com/noais" target="_blank" rel="noopener" class="contact-link">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
          GitHub
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ─── FOOTER ────────────────────────────────────────────────────── -->
<footer class="footer">
  <p>David Ferreira · Portugal · <span id="year"></span></p>
  <script>document.getElementById('year').textContent = new Date().getFullYear().toString();</script>
</footer>

</Layout>

<style>
/* ── Nav ───────────────────────────────────────────────────────── */
.nav-shell {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  background: rgba(13,15,26,0.85);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  border-bottom: 1px solid rgba(237,233,226,0.07);
}
.nav-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 2rem;
  height: 60px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.nav-logo {
  font-family: 'Fraunces', Georgia, serif;
  font-size: 1.25rem;
  font-weight: 600;
  color: var(--ink);
  text-decoration: none;
  letter-spacing: -0.02em;
}
.nav-links {
  display: flex;
  align-items: center;
  gap: 2rem;
  list-style: none;
  margin: 0; padding: 0;
}
.nav-links a {
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--muted);
  text-decoration: none;
  transition: color 0.15s;
}
.nav-links a:hover,
.nav-links a[data-active] { color: var(--ink); }
.nav-cta {
  background: var(--lime);
  color: #0D0F1A !important;
  padding: 0.5rem 1.125rem;
  border-radius: 100px;
  transition: background 0.15s !important;
}
.nav-cta:hover { background: #d4ff3a !important; color: #0D0F1A !important; }

/* ── Hero ──────────────────────────────────────────────────────── */
.hero-section {
  padding-top: 120px;
  padding-bottom: 80px;
  overflow: hidden;
}
.hero-grid {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 2rem;
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  gap: 4rem;
  min-height: 80vh;
}
.hero-chips {
  display: flex;
  gap: 0.5rem;
  margin-bottom: 2rem;
  flex-wrap: wrap;
}
.chip {
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--muted);
  border: 1px solid rgba(237,233,226,0.10);
  border-radius: 100px;
  padding: 0.3rem 0.875rem;
  background: rgba(237,233,226,0.04);
}
.hero-headline {
  font-family: 'Fraunces', Georgia, serif;
  font-size: clamp(2.75rem, 6vw, 5rem);
  font-weight: 400;
  line-height: 1.05;
  letter-spacing: -0.03em;
  color: var(--ink);
  margin: 0 0 1.5rem;
}
.hero-headline em {
  font-style: italic;
  font-weight: 300;
}
.hero-sub {
  font-size: 1.0625rem;
  line-height: 1.65;
  color: var(--muted);
  max-width: 38ch;
  margin: 0 0 2.5rem;
}
.hero-actions {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
}
.btn-primary {
  display: inline-flex;
  align-items: center;
  background: var(--lime);
  color: #0D0F1A;
  font-weight: 600;
  font-size: 0.9375rem;
  padding: 0.75rem 1.75rem;
  border-radius: 100px;
  text-decoration: none;
  transition: background 0.15s;
}
.btn-primary:hover { background: #d4ff3a; }
.btn-ghost {
  display: inline-flex;
  align-items: center;
  border: 1.5px solid rgba(237,233,226,0.15);
  color: var(--ink);
  font-weight: 500;
  font-size: 0.9375rem;
  padding: 0.75rem 1.75rem;
  border-radius: 100px;
  text-decoration: none;
  transition: border-color 0.15s;
}
.btn-ghost:hover { border-color: rgba(237,233,226,0.35); }

/* Phone stack */
.hero-visual {
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
  height: 560px;
}
.phone-stack {
  position: relative;
  width: 240px;
  height: 480px;
}
.phone {
  position: absolute;
  width: 220px;
  border-radius: 32px;
  overflow: hidden;
  box-shadow: 0 32px 80px rgba(26,25,23,0.18), 0 8px 24px rgba(26,25,23,0.10);
}
.phone img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.phone--back {
  top: 32px;
  left: -48px;
  height: 420px;
  transform: rotate(-6deg);
  opacity: 0.80;
  z-index: 1;
}
.phone--front {
  top: 0;
  left: 56px;
  height: 460px;
  transform: rotate(3deg);
  z-index: 2;
}
.hero-topo {
  position: absolute;
  inset: 0;
  background-image: radial-gradient(ellipse 60% 40% at 60% 50%, rgba(198,241,53,0.09) 0%, transparent 70%);
  pointer-events: none;
  z-index: 0;
}

/* ── Proof strip ──────────────────────────────────────────────── */
.proof-strip {
  background: var(--navy);
  padding: 1.375rem 2rem;
  display: flex;
  align-items: center;
  gap: 2.5rem;
  flex-wrap: wrap;
}
.proof-label {
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.30);
  white-space: nowrap;
  margin: 0;
  flex-shrink: 0;
}
.proof-domains {
  display: flex;
  gap: 0;
  list-style: none;
  margin: 0; padding: 0;
  flex-wrap: wrap;
}
.proof-domains li {
  font-size: 0.8125rem;
  font-weight: 500;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.60);
  padding: 0 1.5rem;
  border-right: 1px solid rgba(255,255,255,0.10);
}
.proof-domains li:first-child { padding-left: 0; }
.proof-domains li:last-child { border-right: none; }

/* ── Sections ──────────────────────────────────────────────────── */
.section {
  padding: 100px 0;
}
.section--navy { background: var(--navy); border-top: 1px solid rgba(237,233,226,0.05); }
.section-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 2rem;
}
.section-header { margin-bottom: 4rem; }
.section-header--light .section-title { color: #fff; }
.eyebrow {
  display: block;
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--lime);
  margin-bottom: 0.75rem;
}
.eyebrow--lime { color: var(--lime); }
.section-title {
  font-family: 'Fraunces', Georgia, serif;
  font-size: clamp(1.75rem, 3.5vw, 2.75rem);
  font-weight: 400;
  letter-spacing: -0.025em;
  color: var(--ink);
  margin: 0;
  line-height: 1.15;
}
.section-title--light { color: var(--ink); }

/* ── Case cards ───────────────────────────────────────────────── */
.case-card {
  border-radius: 20px;
  overflow: hidden;
  border: 1px solid rgba(237,233,226,0.07);
  margin-bottom: 1.5rem;
  background: var(--bg2);
}
.case-card--flagship {
  display: grid;
  grid-template-columns: 1fr 1fr;
}
.case-screens {
  background: rgba(237,233,226,0.03);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 3rem 1.5rem 0;
  gap: 0.625rem;
  min-height: 440px;
  overflow: hidden;
}
.case-phone {
  border-radius: 18px;
  overflow: hidden;
  box-shadow: 0 16px 48px rgba(26,25,23,0.14);
  flex-shrink: 0;
}
.case-phone img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.case-phone--1 { width: 110px; height: 210px; }
.case-phone--2 { width: 132px; height: 248px; margin-bottom: 24px; }
.case-phone--3 { width: 110px; height: 210px; }
.case-body {
  padding: 3rem;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.case-tag {
  display: inline-block;
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 1rem;
}
.case-title {
  font-family: 'Fraunces', Georgia, serif;
  font-size: clamp(1.5rem, 2.5vw, 2rem);
  font-weight: 400;
  color: var(--ink);
  margin: 0 0 1.25rem;
  letter-spacing: -0.02em;
}
.case-problem,
.case-outcome {
  font-size: 0.9375rem;
  color: rgba(237,233,226,0.60);
  line-height: 1.6;
  margin: 0 0 0.875rem;
}
.case-problem strong,
.case-outcome strong { color: var(--ink); font-weight: 600; }
.case-stack {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
  margin: 1.25rem 0;
}
.case-stack span {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.7rem;
  background: rgba(237,233,226,0.05);
  color: var(--muted);
  padding: 0.25rem 0.6rem;
  border-radius: 4px;
  border: 1px solid rgba(237,233,226,0.08);
}
.case-link {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  font-size: 0.9375rem;
  font-weight: 600;
  color: var(--ink);
  text-decoration: underline;
  text-underline-offset: 3px;
  text-decoration-color: var(--lime);
  transition: color 0.15s;
  margin-top: auto;
}
.case-link:hover { color: #3a3835; }
.case-card--secondary .case-body { padding: 2.5rem 3rem; }

/* ── Experience timeline ───────────────────────────────────────── */
.timeline {
  list-style: none;
  margin: 0; padding: 0;
  border-left: 1px solid rgba(255,255,255,0.08);
}
.timeline-item {
  display: grid;
  grid-template-columns: 180px 1fr;
  gap: 2rem;
  padding: 0 0 3rem 2.5rem;
  position: relative;
}
.timeline-item:last-child { padding-bottom: 0; }
.timeline-item::before {
  content: '';
  position: absolute;
  left: -5px;
  top: 6px;
  width: 9px;
  height: 9px;
  border-radius: 50%;
  background: var(--lime);
}
.timeline-period {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.75rem;
  color: rgba(255,255,255,0.30);
  letter-spacing: 0.02em;
  padding-top: 2px;
  line-height: 1.4;
}
.timeline-role {
  font-size: 1rem;
  font-weight: 600;
  color: #fff;
  margin: 0 0 0.2rem;
}
.timeline-company {
  font-size: 0.875rem;
  color: rgba(255,255,255,0.40);
  margin: 0 0 1rem;
}
.timeline-outcomes {
  margin: 0; padding: 0;
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.timeline-outcomes li {
  font-size: 0.9375rem;
  color: rgba(255,255,255,0.65);
  line-height: 1.55;
  padding-left: 1.1rem;
  position: relative;
}
.timeline-outcomes li::before {
  content: '→';
  position: absolute;
  left: 0;
  color: var(--lime);
  font-size: 0.7rem;
  top: 4px;
}

/* ── Capabilities ─────────────────────────────────────────────── */
.caps-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.5px;
  background: rgba(255,255,255,0.07);
  border-radius: 16px;
  overflow: hidden;
}
.cap-panel {
  background: rgba(255,255,255,0.03);
  padding: 2.5rem;
  transition: background 0.15s;
}
.cap-panel:hover { background: rgba(255,255,255,0.06); }
.cap-title {
