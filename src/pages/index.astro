---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- NAV -->
  <header
    id="top"
    style="position:fixed;top:0;left:0;right:0;z-index:50;backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);background:rgba(13,17,23,0.8);border-bottom:1px solid rgba(255,255,255,0.06);"
  >
    <nav
      style="max-width:1100px;margin:0 auto;padding:0 1.5rem;height:60px;display:flex;align-items:center;justify-content:space-between;"
      aria-label="Primary navigation"
    >
      <a
        href="#top"
        aria-label="David Ferreira — back to top"
        style="font-weight:700;font-size:0.95rem;letter-spacing:-0.02em;color:#ffffff;text-decoration:none;"
      >
        DF
      </a>
      <ul
        role="list"
        style="display:flex;gap:1.75rem;list-style:none;margin:0;padding:0;"
        class="nav-links"
      >
        {[
          ['about', 'About'],
          ['work', 'Work'],
          ['experience', 'Experience'],
          ['capabilities', 'Capabilities'],
          ['contact', 'Contact'],
        ].map(([id, label]) => (
          <li>
            <a
              href={`#${id}`}
              data-nav={id}
              class="nav-link"
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </header>

  <main>
    <!-- HERO -->
    <section
      id="hero"
      aria-labelledby="hero-heading"
      style="min-height:100svh;display:flex;align-items:center;padding:8rem 1.5rem 5rem;position:relative;overflow:hidden;"
    >
      <!-- Background visual -->
      <div aria-hidden="true" class="hero-bg">
        <div class="hero-orb-cyan"></div>
        <div class="hero-orb-navy"></div>
        <div class="hero-grid"></div>
      </div>

      <div style="max-width:1100px;margin:0 auto;width:100%;position:relative;">
        <div style="max-width:760px;">
          <p class="hero-eyebrow" aria-label="Location: Portugal, remote-friendly">
            <span aria-hidden="true" class="eyebrow-line"></span>
            Portugal · Remote-friendly
          </p>
          <h1 id="hero-heading" class="hero-h1">
            Engineering leader building thoughtful mobile products and AI-augmented software.
          </h1>
          <p class="hero-sub">
            I combine 15+ years of software engineering with hands-on product delivery—from Swift
            and real-time mobile systems to practical AI workflows, reliable releases, and teams
            that ship.
          </p>
          <div class="hero-ctas">
            <a href="#work" class="btn-primary">
              View projects
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <a
              href="https://www.linkedin.com/in/david-ferreira-69041367/"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-secondary"
            >
              Connect on LinkedIn
            </a>
          </div>
        </div>
      </div>

      <div aria-hidden="true" class="scroll-indicator">
        <span>scroll</span>
        <div class="scroll-line"></div>
      </div>
    </section>

    <!-- ABOUT -->
    <section
      id="about"
      aria-labelledby="about-heading"
      class="section-alt"
    >
      <div class="container">
        <div class="two-col-grid">
          <div class="reveal">
            <p class="eyebrow">About</p>
            <h2 id="about-heading" class="section-h2">
              Building software that holds up.
            </h2>
            <div class="prose">
              <p>
                I build durable mobile products—the kind that stay coherent under pressure, stay
                maintainable as teams grow, and stay useful as requirements shift. My work spans
                architecture and real-time systems, analytical AI use, and the release infrastructure
                that makes delivery predictable.
              </p>
              <p>
                I apply AI tools with engineering discipline: Claude Code and Codex accelerate
                planning, implementation, and review in my daily workflow, but human judgment—on
                architecture, correctness, and user experience—drives the decisions that matter.
              </p>
              <p>
                Based in Portugal, I work comfortably across time zones and bring cross-functional
                technical leadership experience from automotive, smart home, telecom, health, secure
                messaging, and outdoor sports domains.
              </p>
            </div>
          </div>

          <div class="reveal reveal-delay-1">
            <div class="info-cards">
              <div class="info-card">
                <p class="card-label">Education</p>
                <p class="card-title">M.Sc. Computers and Telematics Engineering</p>
                <p class="card-sub">University of Aveiro</p>
                <p class="card-note">
                  Thesis: semantic enrichment of SAPO's EPG to improve retrieval across heterogeneous data.
                </p>
              </div>
              <div class="info-card">
                <p class="card-label">Community</p>
                <div class="community-list">
                  <div class="community-item">
                    <span class="community-name">SwiftAveiro</span>
                    <span class="community-meta">Founder &amp; organiser · 2016–2019</span>
                  </div>
                  <div class="community-item">
                    <span class="community-name">CocoaHeads Aveiro</span>
                    <span class="community-meta">Organiser · since 2013</span>
                  </div>
                  <div class="community-item">
                    <span class="community-name">Charts</span>
                    <span class="community-meta">Open-source contributor</span>
                  </div>
                </div>
              </div>
              <div class="info-card">
                <p class="card-label">Languages</p>
                <div class="lang-list">
                  <span class="lang-item">🇵🇹 Portuguese <span class="lang-level">Native</span></span>
                  <span class="lang-item">🇬🇧 English <span class="lang-level">Professional</span></span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- SELECTED WORK -->
    <section id="work" aria-labelledby="work-heading" class="section-default">
      <div class="container">
        <p class="reveal eyebrow">Selected work</p>
        <h2 id="work-heading" class="reveal section-h2">Personal products.</h2>

        <div class="work-grid">

          <!-- RidersNow -->
          <article
            class="reveal project-card project-card--ocean"
            aria-label="RidersNow — live project"
          >
            <div aria-hidden="true" class="ocean-decoration">
              <svg viewBox="0 0 280 280" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
                <circle cx="200" cy="80" r="120" stroke="url(#og1)" stroke-width="1" fill="none" opacity="0.5"/>
                <circle cx="200" cy="80" r="90" stroke="url(#og1)" stroke-width="0.5" fill="none" opacity="0.4"/>
                <circle cx="200" cy="80" r="60" stroke="#00c2d1" stroke-width="0.5" fill="none" opacity="0.3"/>
                <path d="M0 160 Q70 120 140 160 Q210 200 280 160" stroke="url(#og1)" stroke-width="1.5" fill="none" opacity="0.6"/>
                <path d="M0 190 Q70 150 140 190 Q210 230 280 190" stroke="url(#og1)" stroke-width="1" fill="none" opacity="0.4"/>
                <path d="M0 220 Q70 180 140 220 Q210 260 280 220" stroke="#00c2d1" stroke-width="0.8" fill="none" opacity="0.3"/>
                <defs>
                  <linearGradient id="og1" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" stop-color="#125395"/>
                    <stop offset="100%" stop-color="#00c2d1"/>
                  </linearGradient>
                </defs>
              </svg>
            </div>
            <div class="project-content">
              <div class="project-status project-status--live">
                <span class="status-dot status-dot--live" aria-hidden="true"></span>
                Live
              </div>
              <h3 class="project-title">RidersNow</h3>
              <p class="project-desc">
                RidersNow helps people see who is on the water near them in real time—across
                kitesurfing, surfing, windsurfing, and wingfoiling—so they can plan sessions,
                join others, and meet riders.
              </p>
              <div class="tag-list" aria-label="Technologies and tags">
                {['iOS', 'Android', 'SwiftUI', 'Jetpack Compose', 'Kotlin', 'Real-time', 'Mobile product', 'Outdoor sports'].map((tag) => (
                  <span class="tag tag--cyan">{tag}</span>
                ))}
              </div>
              <a
                href="https://davidferreira.dev/ridersnow-site"
                target="_blank"
                rel="noopener noreferrer"
                class="btn-primary btn-sm"
              >
                Visit RidersNow
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>
          </article>

          <!-- FinPilot -->
          <article
            class="reveal reveal-delay-1 project-card project-card--dark"
            aria-label="FinPilot — upcoming product"
          >
            <div aria-hidden="true" class="finance-decoration">
              <svg viewBox="0 0 280 280" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
                <rect x="40" y="180" width="24" height="60" rx="3" fill="#4b5563"/>
                <rect x="80" y="140" width="24" height="100" rx="3" fill="#4b5563"/>
                <rect x="120" y="100" width="24" height="140" rx="3" fill="#4b5563"/>
                <rect x="160" y="120" width="24" height="120" rx="3" fill="#4b5563"/>
                <rect x="200" y="80" width="24" height="160" rx="3" fill="#4b5563"/>
                <path d="M52 195 L92 158 L132 118 L172 132 L212 95" stroke="#6b7280" stroke-width="2" stroke-linecap="round" fill="none"/>
                <line x1="30" y1="240" x2="250" y2="240" stroke="#374151" stroke-width="0.5"/>
                <line x1="30" y1="200" x2="250" y2="200" stroke="#374151" stroke-width="0.5" stroke-dasharray="4 4"/>
                <line x1="30" y1="160" x2="250" y2="160" stroke="#374151" stroke-width="0.5" stroke-dasharray="4 4"/>
                <line x1="30" y1="120" x2="250" y2="120" stroke="#374151" stroke-width="0.5" stroke-dasharray="4 4"/>
                <line x1="30" y1="80" x2="250" y2="80" stroke="#374151" stroke-width="0.5" stroke-dasharray="4 4"/>
              </svg>
            </div>
            <div class="project-content">
              <div class="project-status project-status--soon">
                <span class="status-dot" aria-hidden="true"></span>
                Coming soon
              </div>
              <h3 class="project-title">FinPilot</h3>
              <p class="project-desc project-desc--muted">
                FinPilot is an upcoming product. More soon.
              </p>
              <div class="tag-list" aria-label="Status">
                <span class="tag tag--dim">In development</span>
              </div>
              <span class="btn-disabled" aria-hidden="true">Stay tuned</span>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- EXPERIENCE -->
    <section
      id="experience"
      aria-labelledby="experience-heading"
      class="section-alt"
    >
      <div class="container">
        <p class="reveal eyebrow">Experience</p>
        <h2 id="experience-heading" class="reveal section-h2">15+ years of software.</h2>

        <div class="timeline">
          <div class="timeline-line" aria-hidden="true"></div>

          {[
            {
              role: 'Head of Mobile / Lead Engineer',
              company: 'FRiNGE',
              period: 'Nov 2025 – Apr 2026',
              detail:
                'Built a location-based livestreaming iOS product end to end, including Swift 6/SwiftUI, Agora RTC, Supabase, PostHog, and production work around real-time camera/RTC handoff and concurrency safety.',
              tags: ['Swift 6', 'SwiftUI', 'Agora RTC', 'Supabase', 'PostHog'],
            },
            {
              role: 'Senior iOS Developer',
              company: 'CARIAD (Volkswagen Group)',
              period: 'Nov 2023 – Nov 2025',
              detail:
                'Automotive platform architecture, release flows, onboarding, technical alignment across teams, and tooling using Python, Bash, YAML, APNs, and MQTT.',
              tags: ['iOS', 'Automotive', 'Python', 'APNs', 'MQTT'],
            },
            {
              role: 'Lead iOS Developer',
              company: 'YEO Messaging',
              period: 'Jul 2021 – Oct 2023',
              detail:
                'Security-sensitive messaging capabilities including CoreML + ARKit recipient verification, OLM encryption, GraphQL, WebSockets, snapshot testing, and Bitrise CI.',
              tags: ['CoreML', 'ARKit', 'OLM', 'GraphQL', 'WebSockets'],
            },
            {
              role: 'Lead iOS Developer',
              company: 'Prozis · ProzisGo',
              period: 'Apr 2017 – Jun 2021',
              detail:
                'Led mobile architecture for a health/nutrition product using wearable data; introduced disciplined TDD and built internal SDKs.',
              tags: ['iOS', 'Architecture', 'TDD', 'HealthKit', 'Internal SDK'],
            },
            {
              role: 'iOS Developer',
              company: 'Bosch',
              period: 'Mar 2014 – Apr 2017',
              detail:
                'Smart-home and BLE installer products, including architecture and communication protocol design.',
              tags: ['iOS', 'BLE', 'Smart home', 'Protocol design'],
            },
            {
              role: 'IT Consultant',
              company: 'Portugal Telecom',
              period: 'Jul 2010 – Mar 2014',
              detail:
                'Backend and platform work using Java, Spring, Ruby on Rails, PostgreSQL, Bash, and enterprise systems.',
              tags: ['Java', 'Spring', 'Ruby on Rails', 'PostgreSQL'],
            },
          ].map((item, i) => (
            <div class={`reveal timeline-item${i === 0 ? ' reveal-delay-0' : ''}`}>
              <div class="timeline-dot" aria-hidden="true"></div>
              <div class="timeline-card">
                <div class="timeline-header">
                  <h3 class="timeline-role">{item.role}</h3>
                  <time class="timeline-period">{item.period}</time>
                </div>
                <p class="timeline-company">{item.company}</p>
                <p class="timeline-detail">{item.detail}</p>
                <div class="tag-list" aria-label="Technologies">
                  {item.tags.map((tag) => (
                    <span class="tag tag--mono">{tag}</span>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CAPABILITIES -->
    <section id="capabilities" aria-labelledby="capabilities-heading" class="section-default">
      <div class="container">
        <p class="reveal eyebrow">Capabilities</p>
        <h2 id="capabilities-heading" class="reveal section-h2">Tools and disciplines.</h2>

        <div class="caps-grid">
          {[
            {
              icon: '📱',
              iconLabel: 'Mobile phone',
              title: 'Mobile & Architecture',
              items: ['Swift', 'SwiftUI', 'iOS', 'Kotlin', 'Jetpack Compose', 'Android', 'Objective-C', 'Clean Architecture', 'MVVM', 'TCA', 'Swift concurrency'],
            },
            {
              icon: '🧠',
              iconLabel: 'Brain',
              title: 'AI & Intelligent Systems',
              items: ['Claude Code', 'Codex', 'CoreML', 'ARKit', 'Prompt design', 'Output evaluation', 'Semantic retrieval'],
            },
            {
              icon: '🚀',
              iconLabel: 'Rocket',
              title: 'Delivery & Quality',
              items: ['TDD', 'XCTest', 'Snapshot testing', 'GitHub Actions', 'Fastlane', 'Bitrise', 'Jenkins', 'Release management'],
            },
            {
              icon: '⚙️',
              iconLabel: 'Gear',
              title: 'Systems & Data',
              items: ['Python', 'Supabase', 'Postgres', 'REST', 'GraphQL', 'WebSockets', 'MQTT', 'BLE', 'Agora RTC', 'PostHog'],
            },
          ].map((group) => (
            <div class="reveal cap-card">
              <div class="cap-icon" role="img" aria-label={group.iconLabel}>{group.icon}</div>
              <h3 class="cap-title">{group.title}</h3>
              <div class="tag-list">
                {group.items.map((item) => (
                  <span class="tag tag--cyan-soft">{item}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- PRINCIPLES -->
    <section
      aria-labelledby="principles-heading"
      class="section-principles"
    >
      <div class="container">
        <p class="reveal eyebrow">Principles</p>
        <h2 id="principles-heading" class="reveal section-h2">How I work.</h2>
        <div class="principles-grid">
          {[
            'Ship with context, not just velocity.',
            'Use AI to accelerate craft—not to avoid accountability.',
            'Make quality and delivery systems part of the product.',
            'Turn recurring problems into reusable tools and clear decisions.',
          ].map((principle) => (
            <div class="reveal principle-card">
              <p class="principle-text">"{principle}"</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CONTACT -->
    <section id="contact" aria-labelledby="contact-heading" class="section-default">
      <div class="container container--centered">
        <p class="reveal eyebrow">Contact</p>
        <h2 id="contact-heading" class="reveal section-h2 section-h2--centered">
          Have a product, platform, or engineering challenge worth solving?
        </h2>
        <p class="reveal contact-sub">
          I'm open to conversations about the right problems.
        </p>
        <div class="reveal contact-ctas">
          <a
            href="https://www.linkedin.com/in/david-ferreira-69041367/"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            Connect on LinkedIn
          </a>
          <a
            href="https://github.com/noais"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-secondary"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
            </svg>
            Explore GitHub
          </a>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <p class="footer-copy">
      © {new Date().getFullYear()} David Ferreira · Aveiro, Portugal
    </p>
  </footer>
</Layout>

<style>
  /* ---- Nav ---- */
  .nav-link {
    font-size: 0.85rem;
    font-weight: 500;
    color: rgba(247, 248, 252, 0.6);
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-link:hover,
  .nav-link[data-active="true"] {
    color: #00c2d1;
  }

  /* ---- Hero ---- */
  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .hero-orb-cyan {
    position: absolute;
    top: -10%;
    right: -5%;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(0, 194, 209, 0.12) 0%, transparent 70%);
    filter: blur(40px);
  }
  .hero-orb-navy {
    position: absolute;
    bottom: -10%;
    left: -5%;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(18, 83, 149, 0.18) 0%, transparent 70%);
    filter: blur(60px);
  }
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.025) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: radial-gradient(ellipse at center, black 30%, transparent 80%);
  }
  .hero-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: #00c2d1;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .eyebrow-line {
    display: inline-block;
    width: 32px;
    height: 1px;
    background: #00c2d1;
  }
  .hero-h1 {
    font-size: clamp(2.4rem, 6vw, 4.2rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    color: #ffffff;
  }
  .hero-sub {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: rgba(247, 248, 252, 0.65);
    max-width: 600px;
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }
  .hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: center;
  }
  .scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    opacity: 0.4;
  }
  .scroll-indicator span {
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: #ffffff;
  }
  .scroll-line {
    width: 1px;
    height: 32px;
    background: linear-gradient(to bottom, rgba(255, 255, 255, 0.6), transparent);
  }

  /* ---- Shared layout ---- */
  .section-default {
    padding: 6rem 1.5rem;
  }
  .section-alt {
    padding: 6rem 1.5rem;
    background: rgba(22, 34, 80, 0.3);
  }
  .section-principles {
    padding: 6rem 1.5rem;
    background: linear-gradient(135deg, rgba(15, 25, 56, 0.6) 0%, rgba(22, 34, 80, 0.4) 100%);
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }
  .container {
    max-width: 1100px;
    margin: 0 auto;
  }
  .container--centered {
    text-align: center;
  }
  .two-col-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }
  .eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    color: #00c2d1;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .section-h2 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 800;
