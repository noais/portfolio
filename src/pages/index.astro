---
import Layout from '../layouts/Layout.astro';

const experience = [
  {
    period: '2025–2026',
    role: 'Head of Mobile / Lead Engineer',
    company: 'FRiNGE',
    detail: 'Built a location-based livestreaming iOS product end to end — Swift 6/SwiftUI, Agora RTC, Supabase, PostHog, real-time camera/RTC handoff and concurrency safety.',
    tags: ['Swift 6', 'SwiftUI', 'Agora RTC', 'Supabase', 'PostHog'],
  },
  {
    period: '2023–2025',
    role: 'Senior iOS Developer',
    company: 'CARIAD (Volkswagen Group)',
    detail: 'Automotive platform architecture, release flows, onboarding, technical alignment across teams, tooling with Python, Bash, YAML, APNs, and MQTT.',
    tags: ['iOS', 'Automotive', 'Python', 'APNs', 'MQTT'],
  },
  {
    period: '2021–2023',
    role: 'Lead iOS Developer',
    company: 'YEO Messaging',
    detail: 'Security-sensitive messaging: CoreML + ARKit recipient verification, OLM encryption, GraphQL, WebSockets, snapshot testing, Bitrise CI.',
    tags: ['CoreML', 'ARKit', 'OLM', 'GraphQL', 'WebSockets'],
  },
  {
    period: '2017–2021',
    role: 'Lead iOS Developer',
    company: 'Prozis · ProzisGo',
    detail: 'Led mobile architecture for a health/nutrition product using wearable data; introduced disciplined TDD and built internal SDKs.',
    tags: ['iOS', 'Architecture', 'TDD', 'HealthKit', 'Internal SDK'],
  },
  {
    period: '2014–2017',
    role: 'iOS Developer',
    company: 'Bosch',
    detail: 'Smart-home and BLE installer products, including architecture and communication protocol design.',
    tags: ['iOS', 'BLE', 'Smart home', 'Protocol design'],
  },
  {
    period: '2010–2014',
    role: 'IT Consultant',
    company: 'Portugal Telecom',
    detail: 'Backend and platform work using Java, Spring, Ruby on Rails, PostgreSQL, Bash, and enterprise systems.',
    tags: ['Java', 'Spring', 'Ruby on Rails', 'PostgreSQL'],
  },
];

const capabilities = [
  {
    title: 'Mobile & Architecture',
    items: ['Swift', 'SwiftUI', 'iOS', 'Kotlin', 'Jetpack Compose', 'Android', 'Objective-C', 'Clean Architecture', 'MVVM', 'TCA', 'Swift concurrency'],
  },
  {
    title: 'AI & Intelligent Systems',
    items: ['Claude Code', 'Codex', 'CoreML', 'ARKit', 'Prompt design', 'Output evaluation', 'Semantic retrieval'],
  },
  {
    title: 'Delivery & Quality',
    items: ['TDD', 'XCTest', 'Snapshot testing', 'GitHub Actions', 'Fastlane', 'Bitrise', 'Jenkins', 'Release management'],
  },
  {
    title: 'Systems & Data',
    items: ['Python', 'Supabase', 'Postgres', 'REST', 'GraphQL', 'WebSockets', 'MQTT', 'BLE', 'Agora RTC', 'PostHog'],
  },
];
---

<Layout>

  <!-- ─── NAV ──────────────────────────────────────── -->
  <header class="site-header" id="top">
    <nav class="nav" aria-label="Primary navigation">
      <a href="#top" class="nav-brand">David Ferreira</a>
      <ul class="nav-links" role="list">
        {[['about','About'],['work','Work'],['experience','Experience'],['capabilities','Capabilities'],['contact','Contact']].map(([id, label]) => (
          <li><a href={`#${id}`} data-nav={id} class="nav-link">{label}</a></li>
        ))}
      </ul>
    </nav>
  </header>

  <main>

    <!-- ─── HERO ─────────────────────────────────────── -->
    <section id="hero" class="hero" aria-labelledby="hero-heading">
      <div class="hero-inner">
        <p class="hero-eyebrow">Portugal &middot; Engineering Leader &middot; Mobile</p>
        <div class="hero-rule" aria-hidden="true"></div>
        <h1 id="hero-heading" class="hero-h1">
          Building software<br>
          <em>that holds up.</em>
        </h1>
        <p class="hero-sub">
          15+ years across iOS, real-time systems, and AI-augmented engineering.
          Deep mobile craft combined with cross-functional leadership to ship products
          that stay coherent under pressure.
        </p>
        <div class="hero-ctas">
          <a href="#work" class="cta-primary">View work →</a>
          <a href="https://www.linkedin.com/in/david-ferreira-69041367/" target="_blank" rel="noopener noreferrer" class="cta-ghost">LinkedIn ↗</a>
        </div>
      </div>
      <div class="hero-deco" aria-hidden="true">15</div>
    </section>

    <!-- ─── ABOUT ─────────────────────────────────────── -->
    <section id="about" aria-labelledby="about-heading" class="section section--alt">
      <div class="container">
        <span class="section-label">About</span>
        <div class="about-grid">
          <blockquote class="about-quote">
            "I build durable mobile products&mdash;the kind that stay coherent
            under pressure, maintainable as teams grow, and useful as
            requirements shift."
          </blockquote>
          <div>
            <div class="prose">
              <p>My work spans architecture and real-time systems, analytical AI use, and the release infrastructure that makes delivery predictable.</p>
              <p>I apply AI tools with engineering discipline: Claude Code and Codex accelerate planning, implementation, and review in my daily workflow, but human judgment on architecture, correctness, and user experience drives the decisions that matter.</p>
              <p>Based in Portugal, I work comfortably across time zones and bring cross-functional technical leadership experience from automotive, smart home, telecom, health, secure messaging, and outdoor sports domains.</p>
            </div>
            <dl class="about-meta">
              <div class="meta-row">
                <dt>Education</dt>
                <dd>M.Sc. Computers and Telematics Engineering &middot; University of Aveiro</dd>
              </div>
              <div class="meta-row">
                <dt>Community</dt>
                <dd>SwiftAveiro founder (2016&ndash;19) &middot; CocoaHeads Aveiro organiser &middot; Charts contributor</dd>
              </div>
              <div class="meta-row">
                <dt>Languages</dt>
                <dd>Portuguese (native) &middot; English (professional)</dd>
              </div>
            </dl>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── WORK ──────────────────────────────────────── -->
    <section id="work" aria-labelledby="work-heading" class="section">
      <div class="container">
        <span class="section-label">Selected work</span>
        <h2 id="work-heading" class="section-h2">Personal products.</h2>

        <div class="work-list">
          <!-- RidersNow -->
          <article class="project">
            <div class="project-header">
              <div class="project-meta-row">
                <span class="project-num">01</span>
                <span class="badge badge--live">Live</span>
              </div>
              <a href="https://davidferreira.dev/ridersnow-site" target="_blank" rel="noopener noreferrer" class="project-visit">Visit ↗</a>
            </div>
            <h3 class="project-name">RidersNow</h3>
            <p class="project-desc">Helps people see who is on the water near them in real time&mdash;across kitesurfing, surfing, windsurfing, and wingfoiling&mdash;so they can plan sessions, join others, and meet riders.</p>
            <div class="tag-list">
              {['iOS', 'Android', 'SwiftUI', 'Kotlin', 'Jetpack Compose', 'Real-time', 'Outdoor sports'].map(t => (
                <span class="tag">{t}</span>
              ))}
            </div>
          </article>

          <hr class="divider" />

          <!-- FinPilot -->
          <article class="project project--dim">
            <div class="project-header">
              <div class="project-meta-row">
                <span class="project-num">02</span>
                <span class="badge badge--soon">Soon</span>
              </div>
            </div>
            <h3 class="project-name">FinPilot</h3>
            <p class="project-desc">An upcoming product. More soon.</p>
            <div class="tag-list">
              <span class="tag tag--dim">In development</span>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- ─── EXPERIENCE ────────────────────────────────── -->
    <section id="experience" aria-labelledby="exp-heading" class="section section--alt">
      <div class="container">
        <span class="section-label">Experience</span>
        <h2 id="exp-heading" class="section-h2">15+ years of software.</h2>
        <div class="exp-list">
          {experience.map((item) => (
            <div class="exp-row">
              <span class="exp-period">{item.period}</span>
              <div class="exp-body">
                <div class="exp-heading-row">
                  <span class="exp-role">{item.role}</span>
                  <span class="exp-sep" aria-hidden="true">&middot;</span>
                  <span class="exp-company">{item.company}</span>
                </div>
                <p class="exp-detail">{item.detail}</p>
                <div class="tag-list">
                  {item.tags.map(t => <span class="tag tag--mono">{t}</span>)}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── CAPABILITIES ─────────────────────────────── -->
    <section id="capabilities" aria-labelledby="caps-heading" class="section">
      <div class="container">
        <span class="section-label">Capabilities</span>
        <h2 id="caps-heading" class="section-h2">Tools and disciplines.</h2>
        <div class="caps-grid">
          {capabilities.map(group => (
            <div class="cap-group">
              <h3 class="cap-title">{group.title}</h3>
              <div class="tag-list">
                {group.items.map(item => <span class="tag">{item}</span>)}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── CONTACT ───────────────────────────────────── -->
    <section id="contact" aria-labelledby="contact-heading" class="section section--rust">
      <div class="container container--center">
        <span class="section-label section-label--on-rust">Contact</span>
        <h2 id="contact-heading" class="contact-h2">
          Have a product worth<br>building together?
        </h2>
        <div class="contact-links">
          <a href="https://www.linkedin.com/in/david-ferreira-69041367/" target="_blank" rel="noopener noreferrer" class="cta-white">LinkedIn ↗</a>
          <a href="https://github.com/noais" target="_blank" rel="noopener noreferrer" class="cta-white-ghost">GitHub ↗</a>
        </div>
      </div>
    </section>

  </main>

  <footer class="site-footer">
    <div class="container footer-inner">
      <p>&copy; {new Date().getFullYear()} David Ferreira &middot; Aveiro, Portugal</p>
      <a href="#top" class="footer-top">Back to top ↑</a>
    </div>
  </footer>

</Layout>

<style>
  /* ── Nav ──────────────────────────────────────────── */
  .site-header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: var(--bg);
    border-bottom: 1px solid var(--rule);
  }

  .nav {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-brand {
    font-family: 'Instrument Serif', Georgia, serif;
    font-style: italic;
    font-size: 1.05rem;
    color: var(--fg);
    text-decoration: none;
    transition: color 0.15s;
  }
  .nav-brand:hover { color: var(--rust); }

  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
    margin: 0; padding: 0;
  }

  .nav-link {
    font-size: 0.8rem;
    letter-spacing: 0.02em;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .nav-link:hover,
  .nav-link[data-active="true"] { color: var(--fg); }

  /* ── Hero ─────────────────────────────────────────── */
  .hero {
    min-height: 100svh;
    background-color: var(--bg);
    background-image: radial-gradient(circle, rgba(237,232,223,0.04) 1px, transparent 1px);
    background-size: 26px 26px;
    display: flex;
    align-items: center;
    padding: 9rem 2rem 6rem;
    position: relative;
    overflow: hidden;
  }

  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    position: relative;
    z-index: 1;
  }

  .hero-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 1.25rem;
  }

  .hero-rule {
    width: 36px;
    height: 1px;
    background: var(--rust);
    margin-bottom: 2rem;
  }

  .hero-h1 {
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: clamp(3.2rem, 9vw, 7.5rem);
    font-weight: 400;
    line-height: 1.0;
    letter-spacing: -0.025em;
    color: var(--fg);
    margin-bottom: 2rem;
    max-width: 14ch;
  }
  .hero-h1 em {
    font-style: italic;
    color: var(--rust);
  }

  .hero-sub {
    font-size: clamp(0.95rem, 1.4vw, 1.07rem);
    color: var(--muted);
    line-height: 1.75;
    max-width: 460px;
    margin-bottom: 3rem;
  }

  .hero-ctas {
    display: flex;
    gap: 2rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .cta-primary {
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--fg);
    text-decoration: none;
    border-bottom: 1px solid var(--fg);
    padding-bottom: 2px;
    transition: color 0.15s, border-color 0.15s;
  }
  .cta-primary:hover { color: var(--rust); border-color: var(--rust); }

  .cta-ghost {
    font-size: 0.88rem;
    color: var(--muted);
    text-decoration: none;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 2px;
    transition: color 0.15s, border-color 0.15s;
  }
  .cta-ghost:hover { color: var(--fg); border-color: var(--muted); }

  .hero-deco {
    position: absolute;
    right: -0.04em;
    bottom: -0.14em;
    font-family: 'Instrument Serif', Georgia, serif;
    font-style: italic;
    font-size: clamp(12rem, 32vw, 30rem);
    line-height: 1;
    color: rgba(237,232,223,0.035);
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  /* ── Sections — shared ────────────────────────────── */
  .section     { padding: 6rem 2rem; background: var(--bg); }
  .section--alt { background: var(--bg2); }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }
  .container--center { text-align: center; }

  .section-label {
    display: block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.67rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--rust);
    margin-bottom: 0.85rem;
  }
  .section-label--on-rust { color: rgba(255,255,255,0.55); }

  .section-h2 {
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--fg);
    margin-bottom: 3.5rem;
  }

  /* ── About ────────────────────────────────────────── */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1.35fr;
    gap: 6rem;
    align-items: start;
    margin-top: 2.5rem;
  }

  .about-quote {
    font-family: 'Instrument Serif', Georgia, serif;
    font-style: italic;
    font-size: clamp(1.35rem, 2.2vw, 1.85rem);
    font-weight: 400;
    line-height: 1.42;
    color: var(--fg);
    margin: 0; padding: 0; border: none;
  }

  .prose {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    color: rgba(237,232,223,0.55);
    line-height: 1.75;
    font-size: 0.96rem;
    margin-bottom: 2.75rem;
  }

  .about-meta {
    border-top: 1px solid var(--rule);
    padding-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .meta-row {
    display: grid;
    grid-template-columns: 95px 1fr;
    gap: 1rem;
    align-items: baseline;
  }

  .about-meta dt {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(237,232,223,0.22);
  }

  .about-meta dd {
    font-size: 0.83rem;
    color: rgba(237,232,223,0.42);
    line-height: 1.55;
    margin: 0;
  }

  /* ── Work ─────────────────────────────────────────── */
  .work-list { border-top: 1px solid var(--rule); }

  .project {
    padding: 2.75rem 0;
    border-bottom: 1px solid var(--rule);
  }

  .project--dim .project-name,
  .project--dim .project-desc { opacity: 0.35; }

  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.1rem;
  }

  .project-meta-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .project-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    color: var(--muted);
  }

  .badge {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 2px 7px;
    border-radius: 2px;
  }
  .badge--live {
    background: rgba(200,90,42,0.12);
    color: var(--rust);
    border: 1px solid rgba(200,90,42,0.28);
  }
  .badge--soon {
    background: rgba(110,108,105,0.1);
    color: var(--muted);
    border: 1px solid var(--rule);
  }

  .project-visit {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    color: var(--fg);
    text-decoration: none;
    border-bottom: 1px solid rgba(237,232,223,0.2);
    padding-bottom: 1px;
    letter-spacing: 0.04em;
    transition: color 0.15s, border-color 0.15s;
  }
  .project-visit:hover { color: var(--rust); border-color: var(--rust); }

  .project-name {
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: clamp(2.4rem, 5.5vw, 4.5rem);
    font-weight: 400;
    letter-spacing: -0.025em;
    line-height: 1.0;
    color: var(--fg);
    margin-bottom: 1rem;
  }

  .project-desc {
    font-size: 0.94rem;
    color: var(--muted);
    line-height: 1.65;
    max-width: 580px;
    margin-bottom: 1.25rem;
  }

  .divider {
    border: none;
    border-top: 1px solid var(--rule);
    margin: 0;
  }

  /* ── Tags ─────────────────────────────────────────── */
  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .tag {
    display: inline-block;
    padding: 0.22rem 0.6rem;
    font-size: 0.7rem;
    border-radius: 2px;
    background: rgba(200,90,42,0.09);
    color: rgba(237,232,223,0.62);
    border: 1px solid rgba(200,90,42,0.22);
  }

  .tag--dim {
    background: rgba(237,232,223,0.04);
    border-color: var(--rule);
    color: var(--muted);
  }

  .tag--mono {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.63rem;
    background: rgba(237,232,223,0.04);
    border-color: rgba(237,232,223,0.09);
    color: rgba(237,232,223,0.38);
  }

  /* ── Experience ───────────────────────────────────── */
  .exp-list { border-top: 1px solid var(--rule); }

  .exp-row {
    display: grid;
    grid-template-columns: 105px 1fr;
    gap: 2.5rem;
    padding: 2rem 0;
    border-bottom: 1px solid rgba(237,232,223,0.06);
    align-items: start;
  }

  .exp-period {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.68rem;
    color: var(--rust);
    letter-spacing: 0.03em;
    padding-top: 0.25rem;
  }

  .exp-heading-row {
    display: flex;
    align-items: baseline;
    gap: 0.55rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }

  .exp-role {
    font-size: 0.96rem;
    font-weight: 600;
    color: var(--fg);
  }

  .exp-sep { color: rgba(237,232,223,0.15); font-size: 0.8rem; }

  .exp-company {
    font-size: 0.86rem;
    color: rgba(237,232,223,0.35);
  }

  .exp-detail {
    font-size: 0.85rem;
    color: rgba(237,232,223,0.45);
    line-height: 1.65;
    margin-bottom: 0.75rem;
  }

  /* ── Capabilities ─────────────────────────────────── */
  .caps-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3rem 6rem;
  }

  .cap-title {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.67rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(237,232,223,0.35);
    margin-bottom: 0.85rem;
  }

  /* ── Contact ──────────────────────────────────────── */
  .section--rust { background: var(--rust); }

  .contact-h2 {
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: clamp(2.6rem, 6vw, 5.2rem);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: #fff;
    margin: 1rem 0 2.5rem;
  }

  .contact-links {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta-white {
    font-size: 0.9rem;
    font-weight: 500;
    color: #fff;
    text-decoration: none;
    border-bottom: 1px solid rgba(255,255,255,0.45);
    padding-bottom: 2px;
    transition: border-color 0.15s;
  }
  .cta-white:hover { border-color: #fff; }

  .cta-white-ghost {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.6);
    text-decoration: none;
    border-bottom: 1px solid rgba(255,255,255,0.22);
    padding-bottom: 2px;
    transition: color 0.15s, border-color 0.15s;
  }
  .cta-white-ghost:hover { color: #fff; border-color: rgba(255,255,255,0.45); }

  /* ── Footer ───────────────────────────────────────── */
  .site-footer {
    background: var(--bg);
    padding: 1.75rem 2rem;
    border-top: 1px solid var(--rule);
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.76rem;
    color: rgba(237,232,223,0.22);
  }

  .footer-top {
    color: rgba(237,232,223,0.22);
    text-decoration: none;
    font-size: 0.76rem;
    transition: color 0.15s;
  }
  .footer-top:hover { color: var(--fg); }

  /* ── Responsive ───────────────────────────────────── */
  @media (max-width: 860px) {
    .about-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .caps-grid  { grid-template-columns: 1fr; gap: 2rem; }
    .nav-links  { gap: 1.25rem; }
